{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for AgentMap spanmetrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_TEMPO",
      "label": "Tempo",
      "description": "Tempo datasource for AgentMap traces",
      "type": "datasource",
      "pluginId": "tempo",
      "pluginName": "Tempo"
    }
  ],
  "__elements": {},
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "datasource",
      "id": "tempo",
      "name": "Tempo",
      "version": "1.0.0"
    }
  ],
  "annotations": { "list": [] },
  "description": "Workflow and trace exploration for AgentMap. Visualizes workflow execution rates, agent breakdown, storage operations, and provides trace search and service graph capabilities.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "title": "Workflow Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rate of workflow executions per second. Shows how many AgentMap workflows are being triggered over time.",
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(calls_total{span_name=\"agentmap.workflow.run\"}[$__rate_interval]))",
          "legendFormat": "Executions/s",
          "refId": "A"
        }
      ],
      "title": "Execution Rate",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Average workflow execution duration in milliseconds. High values may indicate complex workflows or slow agent processing.",
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5000 },
              { "color": "red", "value": 30000 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(duration_milliseconds_sum{span_name=\"agentmap.workflow.run\"}[$__rate_interval])) / sum(rate(duration_milliseconds_count{span_name=\"agentmap.workflow.run\"}[$__rate_interval]))",
          "legendFormat": "Avg Duration",
          "refId": "A"
        }
      ],
      "title": "Avg Duration",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Ratio of failed workflow executions to total executions. A rising error rate may indicate misconfigured agents or upstream service failures.",
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(rate(calls_total{span_name=\"agentmap.workflow.run\", status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(calls_total{span_name=\"agentmap.workflow.run\"}[$__rate_interval]))",
          "legendFormat": "Error Rate",
          "refId": "A"
        }
      ],
      "title": "Error Rate",
      "type": "stat"
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 5,
      "title": "Agent Breakdown",
      "type": "row",
      "panels": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "Agent execution rate grouped by agent type. Shows which agent types are most active in your workflows.",
          "fieldConfig": {
            "defaults": {
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
          "id": 6,
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
              "expr": "sum by (agentmap_agent_type) (rate(calls_total{span_name=\"agentmap.agent.run\"}[$__rate_interval]))",
              "legendFormat": "{{agentmap_agent_type}}",
              "refId": "A"
            }
          ],
          "title": "Agent Count by Type",
          "type": "timeseries"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "Average agent execution duration by type in milliseconds. Helps identify which agent types are the slowest and may be workflow bottlenecks.",
          "fieldConfig": {
            "defaults": {
              "unit": "ms",
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
          "id": 7,
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
              "expr": "sum by (agentmap_agent_type) (rate(duration_milliseconds_sum{span_name=\"agentmap.agent.run\"}[$__rate_interval])) / sum by (agentmap_agent_type) (rate(duration_milliseconds_count{span_name=\"agentmap.agent.run\"}[$__rate_interval]))",
              "legendFormat": "{{agentmap_agent_type}}",
              "refId": "A"
            }
          ],
          "title": "Agent Duration by Type",
          "type": "timeseries"
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 8,
      "title": "Storage Operations",
      "type": "row",
      "panels": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "Rate of storage read and write operations by backend type. Monitors data access patterns across storage backends (CSV, JSON, Firebase, Chroma, etc.).",
          "fieldConfig": {
            "defaults": {
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
          "id": 9,
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
              "expr": "sum by (agentmap_storage_backend) (rate(calls_total{span_name=\"agentmap.storage.read\"}[$__rate_interval]))",
              "legendFormat": "Read - {{agentmap_storage_backend}}",
              "refId": "A"
            },
            {
              "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
              "expr": "sum by (agentmap_storage_backend) (rate(calls_total{span_name=\"agentmap.storage.write\"}[$__rate_interval]))",
              "legendFormat": "Write - {{agentmap_storage_backend}}",
              "refId": "B"
            }
          ],
          "title": "Read/Write Rate by Backend",
          "type": "timeseries"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "description": "Distribution of storage operation counts by backend and operation type. Shows the volume of records processed per storage operation.",
          "fieldConfig": {
            "defaults": {
              "custom": {
                "drawStyle": "line",
                "lineInterpolation": "smooth",
                "fillOpacity": 10
              }
            },
            "overrides": []
          },
          "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
          "id": 10,
          "targets": [
            {
              "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
              "expr": "sum by (agentmap_storage_backend, span_name) (rate(duration_milliseconds_count{span_name=~\"agentmap.storage.*\"}[$__rate_interval]))",
              "legendFormat": "{{span_name}} - {{agentmap_storage_backend}}",
              "refId": "A"
            }
          ],
          "title": "Record Count Distribution",
          "type": "timeseries"
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 11,
      "title": "Trace Search",
      "type": "row",
      "panels": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "description": "Live trace search for AgentMap workflow executions. Displays recent traces matching the selected workflow filter. Click a trace to explore its full span tree.",
          "gridPos": { "h": 10, "w": 24, "x": 0, "y": 24 },
          "id": 12,
          "targets": [
            {
              "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
              "query": "{name=\"agentmap.workflow.run\" && resource.service.name=\"agentmap\" && span.agentmap.graph.name=~\"$workflow\"}",
              "queryType": "traceql",
              "refId": "A"
            }
          ],
          "title": "Workflow Traces",
          "type": "traces"
        },
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "description": "Tabular view of recent workflow traces with trace ID, span name, duration, and workflow metadata. Use this to find specific traces for detailed investigation.",
          "gridPos": { "h": 8, "w": 24, "x": 0, "y": 34 },
          "id": 13,
          "targets": [
            {
              "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
              "query": "{name=\"agentmap.workflow.run\" && resource.service.name=\"agentmap\"}",
              "queryType": "traceql",
              "refId": "A"
            }
          ],
          "title": "Trace Table",
          "type": "table"
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 42 },
      "id": 14,
      "title": "Service Graph",
      "type": "row",
      "panels": [
        {
          "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
          "description": "Visual node graph showing the flow between agents in workflow executions. Requires Tempo's service-graphs feature to be enabled in your Tempo configuration.",
          "gridPos": { "h": 12, "w": 24, "x": 0, "y": 43 },
          "id": 15,
          "targets": [
            {
              "datasource": { "type": "tempo", "uid": "${DS_TEMPO}" },
              "queryType": "serviceMap",
              "refId": "A"
            }
          ],
          "title": "Agent Flow",
          "type": "nodeGraph"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["agentmap", "workflow", "traces", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
