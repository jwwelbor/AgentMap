        "name": "datasource_prometheus",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Tempo",
        "multi": false,
        "name": "datasource_tempo",
        "options": [],
        "query": "tempo",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(calls_total{span_name=\"agentmap.workflow.run\"}, agentmap_graph_name)",
        "hide": 0,
        "includeAll": true,
        "label": "Workflow",
        "multi": true,
        "name": "workflow",
        "options": [],
        "query": { "qryType": 1, "query": "label_values(calls_total{span_name=\"agentmap.workflow.run\"}, agentmap_graph_name)", "refId": "WorkflowVariable" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(calls_total{span_name=\"agentmap.agent.run\"}, agentmap_agent_type)",
        "hide": 0,
        "includeAll": true,
        "label": "Agent Type",
        "multi": true,
        "name": "agent_type",
        "options": [],
        "query": { "qryType": 1, "query": "label_values(calls_total{span_name=\"agentmap.agent.run\"}, agentmap_agent_type)", "refId": "AgentTypeVariable" },
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "AgentMap Workflow & Trace Explorer",
  "uid": "",
  "version": 0
}
